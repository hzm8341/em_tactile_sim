<mujoco model="em_sensor_rolling">
  <!--
    Rolling demo:
    - Physical pad 40x40mm (sensor_pad geom), sensing cells 7x7 @ 1mm (6x6mm at centre)
    - Ball radius=10mm, mass=100g → contact force ~1N (clearly visible on chart)
    - Ball starts at sensor centre (x=0,y=0) so forces are non-zero from frame 1
    - Slow diagonal initial velocity so the force pattern visibly moves across the array
  -->
  <option gravity="0 0 -9.81" timestep="0.00833"
          solver="Newton" integrator="implicit"
          cone="elliptic" impratio="10"/>

  <default>
    <geom condim="3" solref="0.02 1.0"
          solimp="0.95 0.999 0.001" friction="1.5 0.5 0.01"/>
  </default>

  <worldbody>
    <light pos="0 0 1" dir="0 0 -1"/>
    <geom name="ground" type="plane" size="0.2 0.2 0.01" rgba="0.55 0.55 0.55 1"/>

    <!-- Sensor pad: 40x40mm physical surface, fixed to world -->
    <body name="sensor_body" pos="0 0 0.001">
      <geom name="sensor_pad" type="box"
            size="0.020 0.020 0.001"
            rgba="0.2 0.55 0.9 0.7" mass="0.05"/>
      <!-- 7x7 sensor cell markers: yellow cylinders at each cell centre -->
      <!-- x,y in {-3,-2,-1,0,1,2,3}mm; z=0.0011 (just above pad top at local z=0.001) -->
      <site name="cell_r0c0" type="cylinder" size="0.0004 0.00015" pos="-0.0030 -0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r0c1" type="cylinder" size="0.0004 0.00015" pos="-0.0020 -0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r0c2" type="cylinder" size="0.0004 0.00015" pos="-0.0010 -0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r0c3" type="cylinder" size="0.0004 0.00015" pos=" 0.0000 -0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r0c4" type="cylinder" size="0.0004 0.00015" pos=" 0.0010 -0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r0c5" type="cylinder" size="0.0004 0.00015" pos=" 0.0020 -0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r0c6" type="cylinder" size="0.0004 0.00015" pos=" 0.0030 -0.0030 0.0011" rgba="1 0.85 0 1"/>

      <site name="cell_r1c0" type="cylinder" size="0.0004 0.00015" pos="-0.0030 -0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r1c1" type="cylinder" size="0.0004 0.00015" pos="-0.0020 -0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r1c2" type="cylinder" size="0.0004 0.00015" pos="-0.0010 -0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r1c3" type="cylinder" size="0.0004 0.00015" pos=" 0.0000 -0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r1c4" type="cylinder" size="0.0004 0.00015" pos=" 0.0010 -0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r1c5" type="cylinder" size="0.0004 0.00015" pos=" 0.0020 -0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r1c6" type="cylinder" size="0.0004 0.00015" pos=" 0.0030 -0.0020 0.0011" rgba="1 0.85 0 1"/>

      <site name="cell_r2c0" type="cylinder" size="0.0004 0.00015" pos="-0.0030 -0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r2c1" type="cylinder" size="0.0004 0.00015" pos="-0.0020 -0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r2c2" type="cylinder" size="0.0004 0.00015" pos="-0.0010 -0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r2c3" type="cylinder" size="0.0004 0.00015" pos=" 0.0000 -0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r2c4" type="cylinder" size="0.0004 0.00015" pos=" 0.0010 -0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r2c5" type="cylinder" size="0.0004 0.00015" pos=" 0.0020 -0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r2c6" type="cylinder" size="0.0004 0.00015" pos=" 0.0030 -0.0010 0.0011" rgba="1 0.85 0 1"/>

      <site name="cell_r3c0" type="cylinder" size="0.0004 0.00015" pos="-0.0030  0.0000 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r3c1" type="cylinder" size="0.0004 0.00015" pos="-0.0020  0.0000 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r3c2" type="cylinder" size="0.0004 0.00015" pos="-0.0010  0.0000 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r3c3" type="cylinder" size="0.0004 0.00015" pos=" 0.0000  0.0000 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r3c4" type="cylinder" size="0.0004 0.00015" pos=" 0.0010  0.0000 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r3c5" type="cylinder" size="0.0004 0.00015" pos=" 0.0020  0.0000 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r3c6" type="cylinder" size="0.0004 0.00015" pos=" 0.0030  0.0000 0.0011" rgba="1 0.85 0 1"/>

      <site name="cell_r4c0" type="cylinder" size="0.0004 0.00015" pos="-0.0030  0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r4c1" type="cylinder" size="0.0004 0.00015" pos="-0.0020  0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r4c2" type="cylinder" size="0.0004 0.00015" pos="-0.0010  0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r4c3" type="cylinder" size="0.0004 0.00015" pos=" 0.0000  0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r4c4" type="cylinder" size="0.0004 0.00015" pos=" 0.0010  0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r4c5" type="cylinder" size="0.0004 0.00015" pos=" 0.0020  0.0010 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r4c6" type="cylinder" size="0.0004 0.00015" pos=" 0.0030  0.0010 0.0011" rgba="1 0.85 0 1"/>

      <site name="cell_r5c0" type="cylinder" size="0.0004 0.00015" pos="-0.0030  0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r5c1" type="cylinder" size="0.0004 0.00015" pos="-0.0020  0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r5c2" type="cylinder" size="0.0004 0.00015" pos="-0.0010  0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r5c3" type="cylinder" size="0.0004 0.00015" pos=" 0.0000  0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r5c4" type="cylinder" size="0.0004 0.00015" pos=" 0.0010  0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r5c5" type="cylinder" size="0.0004 0.00015" pos=" 0.0020  0.0020 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r5c6" type="cylinder" size="0.0004 0.00015" pos=" 0.0030  0.0020 0.0011" rgba="1 0.85 0 1"/>

      <site name="cell_r6c0" type="cylinder" size="0.0004 0.00015" pos="-0.0030  0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r6c1" type="cylinder" size="0.0004 0.00015" pos="-0.0020  0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r6c2" type="cylinder" size="0.0004 0.00015" pos="-0.0010  0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r6c3" type="cylinder" size="0.0004 0.00015" pos=" 0.0000  0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r6c4" type="cylinder" size="0.0004 0.00015" pos=" 0.0010  0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r6c5" type="cylinder" size="0.0004 0.00015" pos=" 0.0020  0.0030 0.0011" rgba="1 0.85 0 1"/>
      <site name="cell_r6c6" type="cylinder" size="0.0004 0.00015" pos=" 0.0030  0.0030 0.0011" rgba="1 0.85 0 1"/>
    </body>

    <!-- Ball: 10mm radius (20mm diameter), 100g — large and visible -->
    <!-- z = pad_top(0.002) + ball_radius(0.010) = 0.012 -->
    <body name="ball" pos="0 0 0.012">
      <joint name="ball_joint" type="free"/>
      <geom name="ball_geom" type="sphere" size="0.010"
            mass="0.100" rgba="1 0.15 0.15 1"/>
    </body>
  </worldbody>

  <!-- Ball starts at sensor centre, stationary — user pushes with Ctrl+drag -->
  <keyframe>
    <key name="roll"
         qpos="0 0 0.012 1 0 0 0"
         qvel="0 0 0  0 0 0"/>
  </keyframe>

  <sensor>
    <user name="EM_SENSOR" dim="151"
          objtype="geom" objname="sensor_pad"/>
  </sensor>
</mujoco>
