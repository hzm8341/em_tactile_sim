    </body>

    <!-- 测试用自由落体球（半径 5mm，质量 10g） -->
    <body name="ball" pos="0 0 0.05">
      <joint name="ball_joint" type="free"/>
      <geom name="ball_geom" type="sphere" size="0.005"
            mass="0.01" rgba="1 0.3 0.3 1"/>
    </body>
  </worldbody>

  <sensor>
    <!-- 151 维用户传感器：由 EMSensorCallback 的 mjcb_sensor 回调填充 -->
    <!-- dim = 7*7*3 + 3 + 1 = 151 -->
    <user name="EM_SENSOR" dim="151"
          objtype="geom" objname="sensor_pad"/>
  </sensor>
</mujoco>
