      <site name="cell_6_0" pos="-0.003000 0.003000 0.001500" size="0.0003" rgba="1 0.5 0 0.8"/>
      <site name="cell_6_1" pos="-0.002000 0.003000 0.001500" size="0.0003" rgba="1 0.5 0 0.8"/>
